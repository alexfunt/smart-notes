APP_NAME=Smart Notes API
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_DB=smart_notes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/smart_notes
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/smart_notes_test

TELEGRAM_BOT_TOKEN=
BACKEND_API_URL=http://127.0.0.1:8000
# Публичный URL фронта (Vite по умолчанию). Бот шлёт его в кнопке /start.
# Для Telegram WebApp в проде нужен HTTPS.
WEB_APP_URL=http://localhost:5173
# Разрешённые источники для CORS (через запятую)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Срок жизни Telegram WebApp initData в секундах (рекомендация Telegram — 86400)
WEBAPP_INITDATA_MAX_AGE=86400

# Reminder spacing: 1440 = once per day. Set to 1 only for quick local checks.
TASK_REMINDER_INTERVAL_MINUTES=1440
# Пауза до следующего напоминания = INTERVAL × множитель(вовлечённость). Ниже MIN — чаще, выше MAX — реже.
TASK_REMINDER_ENGAGEMENT_MIN_GAP_MULTIPLIER=0.35
TASK_REMINDER_ENGAGEMENT_MAX_GAP_MULTIPLIER=4.5
REMINDER_MIN_SPACING_MINUTES=1
# Не слать подряд в один чат за один проход планировщика; 0 = отключить.
REMINDER_STAGGER_SECONDS=30
# Разнести следующие срабатывания (сек), 0 = без jitter.
REMINDER_NEXT_CHECK_JITTER_MAX_SECONDS=180

OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat
# База для POST .../chat/completions (OpenAI-совместимые провайдеры). DeepSeek: https://api.deepseek.com/v1 и OPENAI_MODEL=deepseek-chat
LLM_CHAT_BASE_URL=https://api.openai.com/v1
AI_HINT_MIN_ENGAGEMENT_SCORE=0.55