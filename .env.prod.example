# ====== Публичные настройки ======
PUBLIC_DOMAIN=smart-notes.duckdns.org
ACME_EMAIL=you@example.com

# ====== Backend ======
APP_NAME=Smart Notes API
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False

# ====== Postgres ======
POSTGRES_DB=smart_notes
POSTGRES_USER=smartnotes
# Заменить на длинный случайный пароль! openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_TO_RANDOM_HEX

# DATABASE_URL переопределяется в docker-compose из POSTGRES_*.
# Здесь — для запуска вне Docker (миграции, скрипты).
DATABASE_URL=postgresql+asyncpg://smartnotes:CHANGE_ME_TO_RANDOM_HEX@postgres:5432/smart_notes

# ====== Telegram ======
TELEGRAM_BOT_TOKEN=PUT_REAL_BOT_TOKEN_HERE
BACKEND_API_URL=http://backend:8000
# Прод-фронт — тот же домен, что и API.
WEB_APP_URL=https://smart-notes.duckdns.org

# CORS — фронт и API на одном домене, но оставим домен на случай вызовов извне.
CORS_ORIGINS=https://smart-notes.duckdns.org

WEBAPP_INITDATA_MAX_AGE=86400

# ====== Напоминания ======
TASK_REMINDER_INTERVAL_MINUTES=1440
TASK_REMINDER_ENGAGEMENT_MIN_GAP_MULTIPLIER=0.35
TASK_REMINDER_ENGAGEMENT_MAX_GAP_MULTIPLIER=4.5
REMINDER_MIN_SPACING_MINUTES=1
REMINDER_STAGGER_SECONDS=30
REMINDER_NEXT_CHECK_JITTER_MAX_SECONDS=180

# ====== LLM (опционально) ======
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat
LLM_CHAT_BASE_URL=https://api.deepseek.com/v1
AI_HINT_MIN_ENGAGEMENT_SCORE=0.55
